# ---- Stage 1: Build ----
FROM node:20-alpine AS builder

WORKDIR /app

# We need devDependencies (like @nestjs/cli) to run the build command
COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# ---- Stage 2: Production ----
FROM node:20-alpine AS production

WORKDIR /app

# Only install production dependencies here
COPY package*.json ./
RUN npm ci --omit=dev

# Copy only the compiled JS from the builder stage
COPY --from=builder /app/dist ./dist

# Ensure your NestJS app uses port 3000
EXPOSE 3000

CMD ["node", "dist/main.js"]